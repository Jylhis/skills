.devenv/
.devenv*
.direnv/
.direnv
devenv.local.nix
devenv.local.yaml

# upstream-tracker bare partial clones (regenerated by fetch.py)
.cache/

# Python bytecode (helper scripts)
__pycache__/
*.pyc

# Per-machine tool install/runtime state — install scripts regenerate these.
.claude/
.pi/

# Generated claude.ai skill archives (`just package`).
dist/

# Eval harness runtime artefacts. Cassettes and authored cases.yaml are
# tracked; results, expander output, and Pi sentinel marks are not.
evals/results/
!evals/results/.gitkeep
evals/.generated/
evals/.skill_marks
evals/scripts/__pycache__/
