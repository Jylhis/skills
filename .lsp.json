{
  "nix": {
    "command": "nix",
    "args": ["shell", "nixpkgs#nixd", "-c", "nixd"],
    "extensionToLanguage": {
      ".nix": "nix"
    }
  },
  "python": {
    "command": "nix",
    "args": ["shell", "nixpkgs#basedpyright", "-c", "basedpyright-langserver", "--stdio"],
    "extensionToLanguage": {
      ".py": "python",
      ".pyi": "python"
    }
  },
  "go": {
    "command": "nix",
    "args": ["shell", "nixpkgs#gopls", "-c", "gopls", "serve"],
    "extensionToLanguage": {
      ".go": "go"
    }
  }
}
